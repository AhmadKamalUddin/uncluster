<Window x:Class="Uncluster.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Uncluster" Height="520" Width="380"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- Brushes -->
        <SolidColorBrush x:Key="BgBrush"       Color="#0D1117"/>
        <SolidColorBrush x:Key="SurfaceBrush"  Color="#161B22"/>
        <SolidColorBrush x:Key="AccentBrush"   Color="#00B4D8"/>
        <SolidColorBrush x:Key="TextPrimBrush" Color="#F0F6FC"/>
        <SolidColorBrush x:Key="TextMutBrush"  Color="#8B949E"/>
        <SolidColorBrush x:Key="BorderBrush2"  Color="#21262D"/>

        <!-- Icon button (settings / close) -->
        <Style x:Key="IconBtnStyle" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="#8B949E"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="6,4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#21262D"/>
                                <Setter Property="Foreground" Value="#F0F6FC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Main circular toggle button -->
        <Style x:Key="MainBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#00B4D8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width"      Value="190"/>
            <Setter Property="Height"     Value="190"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="Circle"
                                     Fill="{TemplateBinding Background}"
                                     Width="190" Height="190">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#00B4D8" BlurRadius="40"
                                                      ShadowDepth="0" Opacity="0.5"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Circle" Property="Fill" Value="#0096B7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Circle" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Root container with rounded corners -->
    <Border Background="{StaticResource BgBrush}"
            CornerRadius="16"
            BorderBrush="{StaticResource BorderBrush2}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>    <!-- title bar      -->
                <RowDefinition Height="*"/>     <!-- hero / button  -->
                <RowDefinition Height="Auto"/>  <!-- stats panel    -->
                <RowDefinition Height="40"/>    <!-- footer         -->
            </Grid.RowDefinitions>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- ROW 0 · Title bar (drag handle + icons)            -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Border Grid.Row="0" Background="Transparent" CornerRadius="16,16,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="20,0">
                    <TextBlock Text="UNCLUSTER"
                               FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="12"
                               Foreground="{StaticResource TextMutBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="SettingsButton"
                                Style="{StaticResource IconBtnStyle}"
                                Click="SettingsButton_Click"
                                ToolTip="Settings">
                            <TextBlock Text="⚙" FontSize="15" FontFamily="Segoe UI Symbol"/>
                        </Button>
                        <Button Style="{StaticResource IconBtnStyle}"
                                Click="CloseButton_Click"
                                ToolTip="Close"
                                Margin="4,0,0,0">
                            <TextBlock Text="✕" FontSize="13" FontFamily="Segoe UI"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- ROW 1 · Hero section — circular toggle button      -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Grid Grid.Row="1">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                    <Button x:Name="MainToggleButton"
                            Style="{StaticResource MainBtnStyle}"
                            Click="MainToggleButton_Click"
                            HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock x:Name="BtnLabel"
                                       Text="UNCLUSTER"
                                       FontFamily="Segoe UI" FontWeight="Bold" FontSize="17"
                                       Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="BtnSub"
                                       Text="click to focus"
                                       FontFamily="Segoe UI" FontSize="11"
                                       Foreground="#BBFFFFFF" HorizontalAlignment="Center"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Button>

                    <TextBlock x:Name="StatusText"
                               Text="Ready — no processes suspended."
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="{StaticResource TextMutBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,24,0,0"/>
                </StackPanel>
            </Grid>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- ROW 2 · Stats panel (CPU · RAM Freed · Power Plan) -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Border Grid.Row="2"
                    Background="{StaticResource SurfaceBrush}"
                    Margin="16,0,16,16"
                    CornerRadius="10"
                    Padding="20,14">
                <UniformGrid Columns="3">

                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="CpuText"
                                   Text="—"
                                   FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="22"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="CPU"
                                   FontFamily="Segoe UI" FontSize="11"
                                   Foreground="{StaticResource TextMutBrush}"
                                   HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>

                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="RamText"
                                   Text="—"
                                   FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="22"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="RAM Freed"
                                   FontFamily="Segoe UI" FontSize="11"
                                   Foreground="{StaticResource TextMutBrush}"
                                   HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>

                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="PowerText"
                                   Text="Balanced"
                                   FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Power Plan"
                                   FontFamily="Segoe UI" FontSize="11"
                                   Foreground="{StaticResource TextMutBrush}"
                                   HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>

                </UniformGrid>
            </Border>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- ROW 3 · Footer                                      -->
            <!-- ═══════════════════════════════════════════════════ -->
            <TextBlock Grid.Row="3"
                       Text="v0.1.0  ·  open source"
                       FontFamily="Segoe UI" FontSize="11"
                       Foreground="#3D4450"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Grid>
    </Border>

</Window>
